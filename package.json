{
  "name": "univ-sentinel",
  "version": "2.0.0",
  "description": "Cross-stack auto-hooking logging SDK — Node, Browser, React, Angular, Python",
  "type": "module",
  "bin": {
    "univ-sentinel": "./cli.js",
    "sentinel-sdk":  "./cli.js"
  },
  "exports": {
    "./node":    "./sentinel-sdk/node/agent.ts",
    "./browser": "./sentinel-sdk/browser/agent.ts",
    "./core":    "./sentinel-sdk/core/types.ts"
  },
  "files": [
    "cli.js",
    "server.ts",
    "sentinel-sdk/**/*"
  ],
  "scripts": {
    "dev":    "tsx server.ts",
    "start":  "tsx server.ts",
    "lint":   "tsc --noEmit",
    "patch":  "node cli.js"
  },
  "keywords": [
    "logging",
    "observability",
    "apm",
    "tracing",
    "clickhouse",
    "sentinel",
    "node",
    "react",
    "angular",
    "python"
  ],
  "dependencies": {
    "@google/genai":        "^1.29.0",
    "@tailwindcss/vite":   "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react":        "^0.546.0",
    "react":               "^19.0.1",
    "react-dom":           "^19.0.1",
    "vite":                "^6.2.3",
    "express":             "^4.21.2",
    "dotenv":              "^17.2.3",
    "motion":              "^12.23.24"
  },
  "devDependencies": {
    "@types/node":    "^22.14.0",
    "@types/express": "^4.17.21",
    "autoprefixer":   "^10.4.21",
    "tailwindcss":    "^4.1.14",
    "tsx":            "^4.21.0",
    "typescript":     "~5.8.2"
  }
}
